{
  "extends": "../../tsconfig.json",
  "include": [
    "src/**/*",
    "types/**/*",
    "*.d.ts",
  ],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": "./",
    "paths": {
      // 路径映射
      "@/*": [
        "./src/*"
      ],
      "#/*": [
        "types/*"
      ],
    },
  },
}
