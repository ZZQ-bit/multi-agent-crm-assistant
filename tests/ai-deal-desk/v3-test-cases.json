{
  "version": "3.0",
  "description": "多Agent智能助手 V3 测试用例集，覆盖 CRM 查询、商机进展总结、沟通内容生成、跟进计划生成、复杂商机评审 5 大场景",
  "created_at": "2026-06-30",
  "test_cases": [
    {
      "id": "crm-query-001",
      "category": "CRM 查询",
      "subcategory": "客户名模糊查询",
      "input": {
        "query": "华为的客户信息",
        "boundObject": null
      },
      "expected_behavior": [
        "调用 search_customers 工具",
        "返回候选客户列表（如有多个）",
        "不声称已读取完整 CRM 详情",
        "结构化展示客户名称、负责人、部门"
      ],
      "expected_time_seconds": 15
    },
    {
      "id": "crm-query-002",
      "category": "CRM 查询",
      "subcategory": "商机名模糊查询",
      "input": {
        "query": "CRM采购项目的商机情况",
        "boundObject": null
      },
      "expected_behavior": [
        "调用 search_opportunities 工具",
        "返回候选商机列表",
        "展示商机名称、金额、阶段、负责人",
        "多候选时请求用户选择"
      ],
      "expected_time_seconds": 15
    },
    {
      "id": "crm-query-003",
      "category": "CRM 查询",
      "subcategory": "多候选对象澄清",
      "input": {
        "query": "腾讯的商机进展",
        "boundObject": null
      },
      "expected_behavior": [
        "返回 OBJECT_AMBIGUOUS 状态",
